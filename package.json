{
  "name": "delta-ts",
  "version": "0.1.0",
  "description": "Lightweight TypeScript reader for Delta Lake tables",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@praha/byethrow": "^0.10.0",
    "hyparquet": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "delta",
    "delta-lake",
    "parquet",
    "data-lake",
    "lakehouse"
  ],
  "author": "iwasa-kosui",
  "repository": {
    "type": "git",
    "url": "https://github.com/iwasa-kosui/delta-ts.git"
  },
  "homepage": "https://github.com/iwasa-kosui/delta-ts#readme",
  "bugs": {
    "url": "https://github.com/iwasa-kosui/delta-ts/issues"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}