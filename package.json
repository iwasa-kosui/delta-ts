{
  "name": "delta-ts",
  "version": "0.1.0",
  "description": "Lightweight TypeScript reader for Delta Lake tables",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./node": {
      "import": {
        "types": "./dist/store-node/index.d.ts",
        "default": "./dist/store-node/index.js"
      },
      "require": {
        "types": "./dist/store-node/index.d.cts",
        "default": "./dist/store-node/index.cjs"
      }
    },
    "./bun": {
      "import": {
        "types": "./dist/store-bun/index.d.ts",
        "default": "./dist/store-bun/index.js"
      },
      "require": {
        "types": "./dist/store-bun/index.d.cts",
        "default": "./dist/store-bun/index.cjs"
      }
    },
    "./deno": {
      "import": {
        "types": "./dist/store-deno/index.d.ts",
        "default": "./dist/store-deno/index.js"
      },
      "require": {
        "types": "./dist/store-deno/index.d.cts",
        "default": "./dist/store-deno/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit && tsc --noEmit -p src/store-bun/tsconfig.json && tsc --noEmit -p src/store-deno/tsconfig.json",
    "test": "vitest run",
    "test:bun": "bun test test/store/BunStore.bun.test.ts",
    "test:deno": "deno test --allow-read --allow-write test/store/DenoStore.deno.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@praha/byethrow": "^0.10.0",
    "hyparquet": "^1.7.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/deno": "^2.5.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "delta",
    "delta-lake",
    "parquet",
    "data-lake",
    "lakehouse"
  ],
  "author": "iwasa-kosui",
  "repository": {
    "type": "git",
    "url": "https://github.com/iwasa-kosui/delta-ts.git"
  },
  "homepage": "https://github.com/iwasa-kosui/delta-ts#readme",
  "bugs": {
    "url": "https://github.com/iwasa-kosui/delta-ts/issues"
  },
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}